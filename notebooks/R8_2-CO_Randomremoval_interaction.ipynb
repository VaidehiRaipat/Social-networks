   "source": [
    "import matplotlib.lines as mlines\n",
    "\n",
    "# --- Ensure CRS alignment ---\n",
    "poi_points_boulder = poi_points_boulder.to_crs(cbg_boulder.crs)\n",
    "poi_poly_boulder = poi_poly_boulder.to_crs(cbg_boulder.crs)\n",
    "\n",
    "# ----------------------------------------\n",
    "# 1️⃣ Size scaling (keep on map)\n",
