   "source": [
    "poi_poly_gdf = poi_final.copy()\n",
    "\n",
    "poi_poly_gdf[\"geometry\"] = poi_poly_gdf[\"polygon_geometry\"].apply(wkt.loads)\n",
    "\n",
    "poi_poly_gdf = gpd.GeoDataFrame(\n",
