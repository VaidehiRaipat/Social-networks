   "id": "e1636465-45fd-46c3-8bbf-974680110030",
   "metadata": {},
   "outputs": [],
   "source": [
    "poi_final[\"z\"] = (\n",
    "    (poi_final[\"post_total\"] - poi_final[\"mu_rand\"])\n",
    "    / poi_final[\"sd_rand\"]\n",
    ")"
   ]
