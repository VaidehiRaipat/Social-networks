    "# Random Counterfactual - user - user ties"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "beebc224-ce77-4c28-81f7-96422757c2aa",
   "metadata": {},
   "source": [
    "Random post = induced subgraph of pre: \n",
    "For a given random removal draw b with survivor set $S_b$ : a dyad–POI record (u,v,poi) survives if : $ u \\in S_b $ and $v \\in S_b$"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6c25e78a-dcdc-4bba-90ce-a8d62b62fedd",
   "metadata": {
    "jp-MarkdownHeadingCollapsed": true,
    "tags": []
   },
   "source": [
    "## Load actual pre"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7d0fccea-f18e-4b9f-9525-ce630903e82a",
   "metadata": {},
   "outputs": [],
   "source": [
    "dyad_path =  os.path.join(base, \"for_ABM\", f\"individual_interac_allusers_{revision}_aligned.csv\")\n",
    "dy = pd.read_csv(dyad_path)\n",
    "dy"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4c3ac2c4-56be-4161-860e-5806dc8695c6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ensure strings\n",
    "dy[\"user_i\"] = dy[\"user_i\"].astype(str)\n",
    "dy[\"user_j\"] = dy[\"user_j\"].astype(str)\n",
    "dy[\"poi\"]    = dy[\"poi\"].astype(str)\n",
    "\n",
    "# pre-only weight per dyad-poi\n",
    "dy[\"pre_sum\"] = dy[[\"Oct2021\", \"Nov2021\"]].sum(axis=1)\n",
    "\n",
    "# keep only dyads that actually exist in pre (optional but speeds up)\n",
    "dy_pre = dy.loc[dy[\"pre_sum\"] > 0, [\"user_i\",\"user_j\",\"poi\",\"pre_sum\", \"evac_status_i\", \"evac_status_j\"]].copy()\n",
    "print(\"dy_pre rows:\", len(dy_pre))\n",
    "dy_pre.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "58ea8762-ffc5-4385-bd16-6db62f37a986",
   "metadata": {},
   "outputs": [],
   "source": [
    "poi_pre = ( # build poi level stats for pre\n",
    "    dy_pre\n",
    "    .groupby(\"poi\", as_index=False)[\"pre_sum\"]\n",
    "    .sum()\n",
    "    .rename(columns={\"pre_sum\": \"pre_total\"})\n",
    ")\n",
    "\n",
    "poi_pre[\"log_pre\"] = np.log1p(poi_pre[\"pre_total\"])\n",
    "\n",
    "pois = poi_pre[\"poi\"].values\n",
    "n_pois = len(pois)\n",
    "\n",
    "poi_to_idx = {p:i for i,p in enumerate(pois)}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3f866536-8899-4a39-af7e-5b82eb5c9fd5",
   "metadata": {},
