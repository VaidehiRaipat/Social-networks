   "id": "96ddc68f-d2ab-435a-bb59-9e2dbfdff4f5",
   "metadata": {},
   "outputs": [],
   "source": [
    "# z_log = +2 → observed post is 2 SD higher than what your random structural null typically produces (unusually high vs null).\n",
    "# z_log = −2 → observed post is 2 SD lower than null (unusually low vs null).\n",
    "# z_log ≈ 0 → observed post is indistinguishable from null expectation."
   ]
  },
  {
   "cell_type": "code",
