   "id": "944f2dcb-8788-4f7b-85bd-4669a8de02d0",
   "metadata": {},
   "outputs": [],
   "source": [
    "poi_final[\"z_log\"] = (\n",
    "    (poi_final[\"log_post\"] - poi_final[\"mu_log_rand\"])\n",
    "    / poi_final[\"sd_log_rand\"]\n",
    ")"
   ]
