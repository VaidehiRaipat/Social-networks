   "cell_type": "code",
   "execution_count": null,
   "id": "ad99040e-8042-46ae-85ca-b2c36638dd03",
   "metadata": {},
   "outputs": [],
   "source": [
    "delta_rand_df = pd.concat(rows, ignore_index=True)\n",
    "print(delta_rand_df.columns)\n",
    "print(delta_rand_df.shape)\n",
    "delta_rand_df.head()"
   ]
